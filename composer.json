{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "src/modal-bootstrap"
        }
    ],
    "require": {
        "php": "^7.3|^8.0",
        "barryvdh/laravel-snappy": "^0.4.8",
        "bensampo/laravel-enum": "^3.4",
        "dcblogdev/laravel-sent-emails": "^1.0",
        "fideloper/proxy": "^4.4",
        "fruitcake/laravel-cors": "^2.0",
        "garygreen/pretty-routes": "^1.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "h4cc/wkhtmltopdf-amd64": "^0.12.4",
        "infureal/artisan-gui": "^2.0",
        "intervention/image": "^2.6",
        "jantinnerezo/livewire-alert": "^2.1",
        "joelbutcher/socialstream": "^3.1",
        "laravel/framework": "^8.40",
        "laravel/sanctum": "^2.6",
        "laravel/telescope": "^4.6",
        "laravel/tinker": "^2.5",
        "league/commonmark": "^2.0",
        "livewire-ui/modal-bootstrap": "dev-main",
        "livewire/livewire": "^2.5",
        "propaganistas/laravel-phone": "^4.3",
        "protonemedia/laravel-mixins": "^3.0",
        "rappasoft/laravel-livewire-tables": "^1.11",
        "sammyjo20/wagonwheel": "^2.0",
        "spatie/eloquent-sortable": "^4.0",
        "spatie/laravel-remote": "^1.0",
        "vaimo/composer-patches": "^4.22",
        "venturecraft/revisionable": "^1.38"
    },
    "require-dev": {
        "andrey-helldar/migrate-db": "^1.2",
        "barryvdh/laravel-debugbar": "^3.6",
        "barryvdh/laravel-ide-helper": "^2.10",
        "davidhsianturi/laravel-compass": "^1.2",
        "facade/ignition": "^2.5",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^5.0",
        "phpunit/phpunit": "^9.3.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "patcher": {
            "search": "patches"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
